{
    "name": "drawde/portafolio",
    "description": "Sitio de portafolio profesional desarrollado con Drupal",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Drawde",
            "role": "Developer"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "php": ">=8.3",
        "composer/installers": "^2.0",
        "drupal/core-composer-scaffold": "^11.0",
        "drupal/core-recommended": "^11.0",
        "drupal/decoupled_router": "^2.0",
        "drupal/field_group": "^3.0",
        "drupal/jsonapi_extras": "^3.0",
        "drupal/metatag": "^2.0",
        "drupal/next": "^2.0",
        "drupal/paragraphs": "^1.17",
        "drupal/pathauto": "^1.12",
        "drupal/simple_oauth": "^6.0",
        "drupal/subrequests": "^3.0",
        "drupal/token": "^1.13",
        "drush/drush": "^13.0"
    },
    "require-dev": {
        "drupal/core-dev": "^11.0",
        "drush/drush": "^13.0"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": true
        },
        "platform": {
            "php": "8.3"
        },
        "sort-packages": true
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ]
        }
    }
}
