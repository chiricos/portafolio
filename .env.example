# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=portafolio_drupal
DB_USER=drupal_user
DB_PASS=secure_password
DB_DRIVER=mysql

# Site Configuration
SITE_NAME="Mi Portafolio"
SITE_URL=http://localhost:8000
SITE_EMAIL=info@portafolio.local

# Admin Configuration
ADMIN_USER=admin
ADMIN_PASS=admin_password
ADMIN_EMAIL=admin@portafolio.local

# Environment
ENVIRONMENT=development
DEBUG=true

# Salt (Genera uno único con: php -r "echo base64_encode(random_bytes(55));"
HASH_SALT=change-me-to-a-random-hash-salt
